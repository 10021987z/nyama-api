// NYAMA API - Prisma Schema
// Marketplace de cuisine camerounaise — Douala & Yaoundé
// Phase 2 : Modèle de données complet

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  CLIENT
  COOK
  RIDER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  ASSIGNED
  PICKED_UP
  DELIVERING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  ORANGE_MONEY
  MTN_MOMO
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DeliveryStatus {
  ASSIGNED
  ARRIVED_RESTAURANT
  PICKED_UP
  ARRIVED_CLIENT
  DELIVERED
}

enum VehicleType {
  MOTO
  VELO
  VOITURE
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  TRIAL
  CANCELLED
}

enum PartnerType {
  COOK
  RIDER
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum DisputeType {
  LATE_DELIVERY
  WRONG_ORDER
  MISSING_ITEM
  FOOD_QUALITY
  RIDER_BEHAVIOR
  COOK_BEHAVIOR
  PAYMENT_ISSUE
  OTHER
}

enum DisputeSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  WAITING_RESPONSE
  RESOLVED
  CLOSED
  ESCALATED
}

enum TicketCategory {
  ORDER_ISSUE
  PAYMENT_ISSUE
  ACCOUNT
  TECHNICAL
  SUGGESTION
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================================
// MODÈLES
// ============================================================

// 1. User — compte commun à tous les rôles
model User {
  id          String   @id @default(uuid())
  phone       String   @unique
  email       String?  @unique
  firebaseUid String?  @unique
  name        String?
  role        UserRole @default(CLIENT)
  firstLoginCode  String?
  firstLoginUsed  Boolean  @default(false)
  quarterId   String?
  quarter     Quarter? @relation(fields: [quarterId], references: [id])
  locationLat Float?
  locationLng Float?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders              Order[]              @relation("ClientOrders")
  cookOrders          Order[]              @relation("CookOrders")
  riderOrders         Order[]              @relation("RiderOrders")
  cookProfile         CookProfile?
  riderProfile        RiderProfile?
  reviews             Review[]
  sentMessages        ChatMessage[]
  notifications       Notification[]
  refreshTokens       RefreshToken[]
  partnerApplications PartnerApplication[]
  clientDisputes      Dispute[]            @relation("DisputeClient")
  supportTickets      SupportTicket[]
}

// 2. Quarter — quartier de Douala ou Yaoundé
model Quarter {
  id       String  @id @default(uuid())
  name     String
  city     String // Douala | Yaoundé
  polygon  String // GeoJSON sérialisé (SQLite ne supporte pas Json natif)
  isActive Boolean @default(true)

  users        User[]
  cookProfiles CookProfile[]

  @@index([city])
}

// 3. CookProfile — profil cuisinière
model CookProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName        String
  specialty          String // JSON array sérialisé ex: '["Ndolé","Eru"]'
  description        String?
  avatarUrl          String?
  avgRating          Float              @default(0)
  totalOrders        Int                @default(0)
  isVerified         Boolean            @default(false)
  isActive           Boolean            @default(true)
  prepTimeAvgMin     Int?
  openingHours       String? // JSON sérialisé { mon:{open,close}, ... }
  momoPhone          String?
  momoProvider       String? // orange | mtn
  quarterId          String
  quarter            Quarter            @relation(fields: [quarterId], references: [id])
  locationLat        Float
  locationLng        Float
  landmark           String?
  languagePref       String             @default("fr")
  subscriptionPlan   SubscriptionPlan   @default(FREE)
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionEndsAt DateTime?
  createdAt          DateTime           @default(now())

  menuItems   MenuItem[]
  cookPayouts CookPayout[]

  @@index([quarterId, isActive])
  @@index([avgRating])
}

// 4. MenuItem — plat proposé par une cuisinière
model MenuItem {
  id             String      @id @default(uuid())
  cookId         String
  cook           CookProfile @relation(fields: [cookId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  priceXaf       Int
  category       String
  imageUrl       String?
  isAvailable    Boolean     @default(true)
  isDailySpecial Boolean     @default(false)
  prepTimeMin    Int?
  stockRemaining Int?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  orderItems OrderItem[]

  @@index([cookId, isAvailable])
  @@index([category])
}

// 5. Order — commande
model Order {
  id              String        @id @default(uuid())
  clientId        String
  client          User          @relation("ClientOrders", fields: [clientId], references: [id])
  cookId          String
  cook            User          @relation("CookOrders", fields: [cookId], references: [id])
  riderId         String?
  rider           User?         @relation("RiderOrders", fields: [riderId], references: [id])
  status          OrderStatus   @default(PENDING)
  totalXaf        Int
  deliveryFeeXaf  Int
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  deliveryAddress String
  deliveryLat     Float
  deliveryLng     Float
  landmark        String?
  clientNote      String?
  cancelReason    String?
  acceptedAt      DateTime?
  readyAt         DateTime?
  assignedAt      DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items        OrderItem[]
  payment      Payment?
  delivery     Delivery?
  reviews      Review[]
  chatMessages ChatMessage[]
  disputes     Dispute[]

  @@index([status])
  @@index([cookId])
  @@index([clientId])
  @@index([riderId])
  @@index([createdAt])
}

// 6. OrderItem — ligne de commande
model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])
  quantity     Int
  unitPriceXaf Int
  subtotalXaf  Int

  @@index([orderId])
}

// 7. Payment — transaction
model Payment {
  id              String        @id @default(uuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amountXaf       Int
  currency        String        @default("XAF")
  providerRef     String?
  providerPayload String? // JSON sérialisé
  paidAt          DateTime?
  failureReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([providerRef])
}

// 8. Delivery — livraison
model Delivery {
  id               String         @id @default(uuid())
  orderId          String         @unique
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  riderId          String
  rider            RiderProfile   @relation(fields: [riderId], references: [id])
  status           DeliveryStatus @default(ASSIGNED)
  pickupLat        Float?
  pickupLng        Float?
  dropoffLat       Float
  dropoffLng       Float
  distanceKm       Float?
  estimatedMinutes Int?
  assignedAt       DateTime       @default(now())
  pickedUpAt       DateTime?
  deliveredAt      DateTime?
  riderEarningXaf  Int?

  riderEarning RiderEarning?

  @@index([riderId, status])
}

// 9. RiderProfile — benskineur
model RiderProfile {
  id           String      @id @default(uuid())
  userId       String      @unique
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleType  VehicleType @default(MOTO)
  plateNumber  String?
  isVerified   Boolean     @default(false)
  isOnline     Boolean     @default(false)
  avgRating    Float       @default(0)
  totalTrips   Int         @default(0)
  momoPhone    String?
  momoProvider String?
  createdAt    DateTime    @default(now())

  deliveries    Delivery[]
  riderEarnings RiderEarning[]

  @@index([isOnline])
}

// 10. Review — avis client
model Review {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])
  cookRating   Int?
  riderRating  Int?
  cookComment  String?
  riderComment String?
  createdAt    DateTime @default(now())

  @@unique([orderId, authorId])
  @@index([orderId])
}

// 11. ChatMessage — messagerie par commande
model ChatMessage {
  id        String    @id @default(uuid())
  orderId   String
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User      @relation(fields: [senderId], references: [id])
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([orderId, createdAt])
}

// 12. Notification
model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  data      String? // JSON sérialisé
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

// 13. CookPayout — virement cuisinière
model CookPayout {
  id          String      @id @default(uuid())
  cookId      String
  cook        CookProfile @relation(fields: [cookId], references: [id])
  amountXaf   Int
  periodStart DateTime
  periodEnd   DateTime
  status      String      @default("PENDING")
  momoRef     String?
  processedAt DateTime?
  createdAt   DateTime    @default(now())

  @@index([cookId, status])
}

// 14. RiderEarning — gain rider par livraison
model RiderEarning {
  id            String       @id @default(uuid())
  riderId       String
  rider         RiderProfile @relation(fields: [riderId], references: [id])
  deliveryId    String       @unique
  delivery      Delivery     @relation(fields: [deliveryId], references: [id])
  grossXaf      Int
  commissionXaf Int
  netXaf        Int
  paidAt        DateTime?
  createdAt     DateTime     @default(now())

  @@index([riderId])
}

// 15. OtpCode — codes OTP SMS
model OtpCode {
  id        String    @id @default(uuid())
  phone     String
  code      String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// 16. RefreshToken — tokens révocables
model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  deviceInfo String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// 17. PartnershipRequest — candidature publique depuis le portail web (pas d'auth)
model PartnershipRequest {
  id              String   @id @default(uuid())
  type            String   // "cuisiniere" ou "livreur"
  firstName       String
  lastName        String
  phone           String
  email           String?
  companyName     String?  // Nom du restaurant/établissement
  description     String?
  city            String
  quarter         String
  vehicleType     String?  // Pour livreurs : moto, velo, voiture, a_pied
  idNumber        String?  // Numéro CNI
  status          String   @default("pending") // pending, under_review, approved, rejected
  adminNotes      String?
  accessCodeHash  String?
  reviewedBy      String?
  reviewedAt      DateTime?

  // Documents KYC livreur
  idDocumentUrl   String?
  selfieUrl       String?
  licenseUrl      String?
  insuranceUrl    String?

  // Statut vérification documents: pending, verified, rejected
  idDocumentStatus String  @default("pending")
  selfieStatus     String  @default("pending")
  licenseStatus    String  @default("pending")
  insuranceStatus  String  @default("pending")

  // Score KYC automatique (0-100), 25 points par document vérifié
  kycScore        Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([type, status])
  @@index([createdAt])
}

// 18. PartnerApplication — candidature cuisinière ou livreur
model PartnerApplication {
  id     String            @id @default(uuid())
  userId String
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   PartnerType
  status ApplicationStatus @default(PENDING)

  // Infos personnelles
  fullName      String
  phone         String
  email         String?
  idNumber      String?
  idDocumentUrl String?
  selfieUrl     String?

  // Cuisinière
  specialties   String? // JSON array
  cookingExp    String?
  kitchenPhotos String? // JSON array d'URLs
  healthCertUrl String?

  // Livreur
  vehicleType   String?
  plateNumber   String?
  licenseUrl    String?
  insuranceUrl  String?
  vehiclePhotos String? // JSON array

  // Validation admin
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  score           Int?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type, status])
  @@index([userId])
}

// 18. Dispute — litige sur une commande
model Dispute {
  id       String  @id @default(uuid())
  orderId  String
  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  clientId String
  client   User    @relation("DisputeClient", fields: [clientId], references: [id])
  cookId   String?
  riderId  String?

  type     DisputeType
  severity DisputeSeverity @default(MEDIUM)
  status   DisputeStatus   @default(OPEN)

  description String
  evidence    String? // JSON array d'URLs photos

  assignedTo      String?
  resolution      String?
  refundAmountXaf Int?
  resolvedAt      DateTime?

  messages DisputeMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([severity])
  @@index([orderId])
  @@index([clientId])
  @@index([createdAt])
}

// 19. DisputeMessage — message dans un litige
model DisputeMessage {
  id         String   @id @default(uuid())
  disputeId  String
  dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  authorId   String
  authorRole String // CLIENT, ADMIN, COOK, RIDER
  message    String
  createdAt  DateTime @default(now())

  @@index([disputeId, createdAt])
}

// 20. SupportTicket — ticket support depuis les apps
model SupportTicket {
  id           String         @id @default(uuid())
  userId       String?
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  reporterRole String // CLIENT, COOK, RIDER, GUEST
  category     TicketCategory
  priority     TicketPriority @default(NORMAL)
  status       TicketStatus   @default(OPEN)
  subject      String
  message      String
  contactPhone String?
  contactEmail String?
  orderId      String?
  attachments  String? // JSON array d'URLs
  assignedTo   String?
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status])
  @@index([priority])
  @@index([userId])
  @@index([createdAt])
}

// 21. AdminAccount — comptes admin du dashboard
model AdminAccount {
  id                String    @id @default(uuid())
  username          String    @unique
  passwordHash      String
  displayName       String
  role              String    @default("ADMIN")
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  loginCount        Int       @default(0)
  createdBy         String?
  passwordExpiresAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// 22. AdminLoginLog — journal de connexions admin
model AdminLoginLog {
  id        String   @id @default(uuid())
  username  String
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())
}

// 23. AdminAuditLog — journal d'audit admin
model AdminAuditLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  target    String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())
}

// 24. DocumentUpload — stockage base64 en BDD des pièces KYC
model DocumentUpload {
  id           String   @id @default(uuid())
  data         String   // base64 du contenu
  mimeType     String
  size         Int
  originalName String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}
