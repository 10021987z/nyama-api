# ================================
# NYAMA API - Environment Variables
# ================================

# Application
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# ================================
# Database (PostgreSQL + PostGIS)
# ================================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nyama_db?schema=public"

# ================================
# Redis
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# TTL en secondes
REDIS_OTP_TTL=300          # 5 minutes
REDIS_SESSION_TTL=1800     # 30 minutes
REDIS_RIDER_POS_TTL=60     # 60 secondes (position GPS)

# ================================
# JWT (RS256)
# ================================
# Générer les clés : openssl genrsa -out private.pem 2048
#                   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ================================
# OTP SMS
# ================================
# Fournisseur SMS Cameroun (ex: SEMAPHORE, AfricasTalking, etc.)
SMS_PROVIDER=africas_talking       # africas_talking | semaphore | orange_api
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=NYAMA
AFRICAS_TALKING_USERNAME=sandbox

# ================================
# Paiements Mobile Money
# ================================
# NotchPay
NOTCHPAY_PUBLIC_KEY=pk.your_notchpay_public_key
NOTCHPAY_PRIVATE_KEY=sk.your_notchpay_private_key
NOTCHPAY_HASH=your_notchpay_webhook_hash
NOTCHPAY_BASE_URL=https://api.notchpay.co

# CamPay (alternative)
CAMPAY_USERNAME=your_campay_username
CAMPAY_PASSWORD=your_campay_password
CAMPAY_BASE_URL=https://demo.campay.net/api   # prod: https://www.campay.net/api

# Orange Money Direct (optionnel)
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_BASE_URL=

# ================================
# Géolocalisation
# ================================
# Rayon max de livraison en km
MAX_DELIVERY_RADIUS_KM=10
# Frais de livraison par km (FCFA)
DELIVERY_FEE_PER_KM=150
DELIVERY_BASE_FEE=500

# ================================
# Commission plateforme
# ================================
PLATFORM_COMMISSION_PERCENT=15   # 15% sur chaque commande
RIDER_COMMISSION_PERCENT=80      # 80% des frais de livraison pour le rider

# ================================
# Socket.IO / WebSockets
# ================================
WS_CORS_ORIGIN=*

# ================================
# Notifications Push (optionnel - Phase ultérieure)
# ================================
FCM_SERVER_KEY=your_firebase_server_key
FCM_PROJECT_ID=your_firebase_project_id

# ================================
# Stockage fichiers (images menus, profils)
# ================================
STORAGE_PROVIDER=local           # local | s3 | cloudinary
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# AWS S3 (si STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=nyama-assets

# Cloudinary (si STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ================================
# Rate Limiting
# ================================
THROTTLE_TTL=60000     # 1 minute (ms)
THROTTLE_LIMIT=100     # 100 requêtes par minute

# ================================
# Logging
# ================================
LOG_LEVEL=debug        # debug | info | warn | error
