# ================================
# NYAMA API — Production Environment
# ================================
# Copier vers .env et remplir les valeurs

# Application
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://nyama.cm,https://admin.nyama.cm

# Base de données PostgreSQL (fournie par Railway)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public

# JWT Secrets
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars

# OTP
OTP_SECRET=your_otp_secret

# Redis (fourni par Railway ou Upstash)
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# SMS Provider
SMS_PROVIDER=africas_talking
SMS_API_KEY=
SMS_SENDER_ID=NYAMA
AFRICAS_TALKING_USERNAME=

# Paiements — NotchPay
NOTCHPAY_PUBLIC_KEY=
NOTCHPAY_PRIVATE_KEY=
NOTCHPAY_HASH=
NOTCHPAY_BASE_URL=https://api.notchpay.co

# Stockage
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=info
